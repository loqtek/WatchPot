# Copy to .env in the repo root, set your public host/IP, then:
#   docker compose up -d --build
#
# Traffic flows: browser → nginx :443 (HTTPS) → web + /api proxy. Port 6040 is Docker-internal only.

# Primary setting — edit this to your VPS IP or hostname:
WATCHPOT_PUBLIC_HOST=your.server.ip.or.name
WATCHPOT_TLS_EXTRA_IPS=your.server.ip.or.name

# Derived from WATCHPOT_PUBLIC_HOST at web build time when left unset (override only if needed):
# NEXT_PUBLIC_API_URL=https://your.server.ip.or.name/api

WATCHPOT_CORS_ORIGINS=https://your.server.ip.or.name,https://localhost,https://127.0.0.1

# Host ports for the TLS proxy (defaults: 443 / 80)
# WATCHPOT_HTTPS_PORT=443
# WATCHPOT_HTTP_PORT=80

# Grafana admin password (compose defaults to "admin" if unset).
# GRAFANA_ADMIN_PASSWORD=change-me

# --- Optional: plain HTTP debugging (not the default) ---
# Expose api/web ports in docker-compose.override.yml and set:
# WATCHPOT_AGENT_API_URL=http://api:6040/api
