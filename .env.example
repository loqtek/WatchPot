# Copy to .env in the repo root — docker compose reads these for builds and runtime.

# ── LAN / remote browser access ───────────────────────────────────────────────
# The API is NOT published on port 6040. Nginx terminates TLS on 443 and proxies /api.
# Use your host IP with HTTPS on port 443 (6040 is internal to Docker only).
#
# Example — UI + API both at https://10.0.50.32 (same origin, no CORS issues):
#   WATCHPOT_PUBLIC_HOST=10.0.50.32
#   WATCHPOT_TLS_EXTRA_IPS=10.0.50.32
#   NEXT_PUBLIC_API_URL=https://10.0.50.32/api
#
# After changing NEXT_PUBLIC_API_URL you MUST rebuild the web image:
#   docker compose up -d --build web proxy
#
# If TLS was already generated without your IP, recreate the cert volume once:
#   docker compose down && docker volume rm watchpot_watchpot_tls && docker compose up -d --build

NEXT_PUBLIC_API_URL=https://localhost/api

# Include LAN origin if you split UI/API across hosts (optional when using nginx same-origin)
WATCHPOT_CORS_ORIGINS=https://localhost,https://127.0.0.1

# Host ports for the TLS proxy (defaults: 443 / 80)
# WATCHPOT_HTTPS_PORT=443
# WATCHPOT_HTTP_PORT=80

# Grafana admin password (compose defaults to "admin" if unset).
# GRAFANA_ADMIN_PASSWORD=change-me

# --- Optional: agent profile (docker compose --profile agent up -d agent) ---
# Register a pot in the UI, then set:
# WATCHPOT_POT_ID=<uuid>
# WATCHPOT_AGENT_TOKEN=wp_...
# Agent container uses the API over the compose network (override if needed):
# WATCHPOT_AGENT_API_URL=http://api:6040/api
