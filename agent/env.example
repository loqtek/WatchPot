WATCHPOT_API_URL=https://your-control-plane.example/api
WATCHPOT_POT_ID=
WATCHPOT_AGENT_TOKEN=
# Required when WATCHPOT_API_URL uses watchPot self-signed TLS (remote agents / install.sh set this):
# WATCHPOT_TLS_CA_FILE=/etc/watchpot/tls/ca.crt
WATCHPOT_POLL_INTERVAL_SEC=45
# Fast loop for UI docker logs / start / stop (seconds).
WATCHPOT_COMMAND_POLL_INTERVAL_SEC=2
WATCHPOT_HEARTBEAT_INTERVAL_SEC=30
WATCHPOT_INFRA_REPORT_INTERVAL_SEC=90
WATCHPOT_WORK_DIR=/var/lib/watchpot
