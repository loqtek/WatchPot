# Copy to .env or run ../setup from the repository root.
# JWT, CORS, and most app settings live in the database after first API startup.

DATABASE_URL=sqlite+aiosqlite:///./data/watchpot.db
# Docker compose default (SQLite volume in the API container — leave unset to use compose default):
# DATABASE_URL=sqlite+aiosqlite:////app/data/watchpot.db
# Browser API URL when building the web image (compose default uses nginx TLS):
# NEXT_PUBLIC_API_URL=https://localhost/api
# Docker compose with PostgreSQL profile (`docker compose --profile postgres up`):
# DATABASE_URL=postgresql+asyncpg://watchpot:watchpot@postgres:5432/watchpot

WATCHPOT_API_ROLE=control
WATCHPOT_STACK_MODE=full

# Local dev: with SQLite (default below) or WATCHPOT_STACK_MODE=local_dev, ./run auto-starts
# the agent and registers a "local-dev" pot on first UI login. Disable with:
# WATCHPOT_AUTO_LOCAL_AGENT=false
#
# Docker compose enables auto local agent by default (see docker-compose.yml).

# Optional first-run hints (also written by ./setup):
# WATCHPOT_CORS_ORIGINS=http://localhost:3020,http://127.0.0.1:3020
# WATCHPOT_EXTERNAL_LOG_PATHS_JSON=["/var/log/honeypots"]

# Local dev / lab (defaults are secure for internet-facing installs):
# EXPOSE_OPENAPI=true
# WATCHPOT_ALLOW_LOOPBACK_CORS=true
# WATCHPOT_LOG_BOOTSTRAP_PASSWORD=true

# Production / VPC:
# EXPOSE_OPENAPI=false
# WATCHPOT_ALLOW_LOOPBACK_CORS=false
# WATCHPOT_LOG_BOOTSTRAP_PASSWORD=false
# WATCHPOT_METRICS_TOKEN=change-me
# WATCHPOT_MAX_BACKUP_UPLOAD_BYTES=536870912
